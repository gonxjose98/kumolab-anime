{
  "crons": [
    {
      "path": "/api/cron?worker=dailydrops",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?worker=processing",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/run-blog-engine",
      "schedule": "30 * * * *"
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}