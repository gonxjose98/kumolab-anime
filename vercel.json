{
  "crons": [
    {
      "path": "/api/cron?worker=detection",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron?worker=dailydrops",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?worker=processing",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron?worker=publish",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron?worker=daily-report",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron?worker=cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron?worker=refresh-meta-token",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron?worker=refresh-threads-token",
      "schedule": "0 5 * * 2"
    },
    {
      "path": "/api/cron?worker=metrics-sync",
      "schedule": "40 */12 * * *"
    },
    {
      "path": "/api/cron?worker=health-monitor",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron?worker=newsletter",
      "schedule": "0 14 * * 0"
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}
