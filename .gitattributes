# Auto detect text files and normalize line endings
* text=auto

# Force specific file types to use LF
*.tsx text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.json text eol=lf
*.js text eol=lf

# Binary files (don't modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
